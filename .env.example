# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
#   cp .env.example .env

# --- Database ---
POSTGRES_DB=tickets
POSTGRES_USER=tickets
POSTGRES_PASSWORD=change-me-use-a-strong-password

# --- API ---
# Host port the API is published on.
API_PORT=8080
# JVM tuning passed to the container.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0

# --- Security ---
# Base64-encoded signing secret, used once JWT auth is wired up.
JWT_SECRET=change-me-base64-encoded-secret
